{
  "name": "王者荣耀灵宝",
  "app_id": "com.tencent.tmgp.sgame",
  "question_channel": "text",
  "input_mode": "unity_focused_paste",
  "input_fallback": "unity_context_paste",
  "screen_size": [3200, 1440],
  "input_point": [1500, 1330],
  "input_placeholder_texts": ["灵宝~"],
  "edit_text_focus_timeout_seconds": 5,
  "input_verify_timeout_seconds": 4,
  "ime_open_wait_seconds": 1.2,
  "long_press_milliseconds": 700,
  "paste_menu_region": [0, 900, 1400, 1300],
  "input_verify_region": [100, 1220, 2760, 1410],
  "page_guard_texts": ["灵宝", "发送"],
  "navigation": [],
  "submit": {"action": "tap", "x": 2930, "y": 1330},
  "response_initial_wait_seconds": 2,
  "response_timeout_seconds": 90,
  "response_poll_interval": 1.2,
  "response_stable_polls": 2,
  "response_use_baseline": false,
  "response_min_chars": 2,
  "ocr_region": [250, 850, 2750, 1135],
  "ocr_line_max_left": 1200,
  "ocr_tile_width": 1000,
  "ocr_tile_overlap": 400,
  "ocr_tile_scale": 2,
  "ocr_line_y_tolerance": 45,
  "ocr_normalize_punctuation": true,
  "ignore_texts": ["返回首页"],
  "ignore_patterns": ["^\\d{1,2}:\\d{2}$", "^\\d{1,3}%$"],
  "join_response_lines": true,
  "response_separator": "\n",
  "recording": true,
  "extraction": ["ocr"]
}
